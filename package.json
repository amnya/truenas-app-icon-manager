{
  "name": "truenas-app-icon-manager",
  "version": "1.0.0",
  "private": true,
  "description": "Self-hosted TrueNAS SCALE helper app for managing custom Apps UI icons.",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "nodemon server/index.js",
    "dev:client": "vite --host 0.0.0.0",
    "build": "vite build",
    "start": "NODE_ENV=production node server/index.js",
    "test": "node --test"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "express": "^4.21.2",
    "js-yaml": "^4.1.0",
    "lucide-react": "^0.468.0",
    "multer": "^2.0.2",
    "vite": "^6.0.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "nodemon": "^3.1.9",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17"
  },
  "engines": {
    "node": ">=20"
  }
}